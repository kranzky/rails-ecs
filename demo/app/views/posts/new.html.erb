<% content_for :title, "New post" %>
<p><%= link_to "← Back", posts_path %></p>
<h1>New post</h1>

<% if @post.errors.any? %>
  <div class="errors">
    <ul>
      <% @post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with url: posts_path, method: :post do |f| %>
  <p><%= f.label :"post[title]", "Title" %><br>
     <%= f.text_field :"post[title]" %></p>
  <p><%= f.label :"post[body]", "Body" %><br>
     <%= f.text_area :"post[body]", rows: 6 %></p>
  <p><%= f.check_box :"post[publish]" %>
     <%= f.label :"post[publish]", "Publish now" %></p>
  <p><%= f.submit "Create post" %></p>
<% end %>
