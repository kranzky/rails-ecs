<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) ? "#{content_for(:title)} · Bulletin" : "Bulletin — built on ECS Rails" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%234f46e5'/><text x='50' y='70' font-size='60' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'>E</text></svg>">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <nav class="site-nav">
      <div class="site-nav__inner">
        <%= link_to root_path, class: "brand" do %>
          <span class="brand__mark">E</span> Bulletin
        <% end %>
        <div class="site-nav__links">
          <%= nav_link "Posts", posts_path, active: controller_name == "posts" %>
          <%= nav_link "People", users_path, active: controller_name == "users" %>
          <%= nav_link "Groups", groups_path, active: %w[groups memberships].include?(controller_name) %>
          <%= nav_link "How it works", about_path, active: controller_name == "pages" %>
        </div>
      </div>
    </nav>

    <%= render "layouts/reset_banner" %>

    <% if flash.any? %>
      <div class="flash">
        <% flash.each do |type, message| %>
          <div class="flash__msg flash__msg--<%= type == "alert" ? "alert" : "notice" %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main><%= yield %></main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>Built on <strong>ECS Rails</strong> — a component-based reimagining of ActiveRecord.</span>
        <span class="site-footer__links">
          <%= link_to "GitHub", "https://github.com/kranzky/ecs_rails" %>
          <span class="dot"></span>
          <%= link_to "RubyGems", "https://rubygems.org/gems/ecs_rails" %>
        </span>
      </div>
    </footer>
  </body>
</html>
